{
  "name": "monitoring-service",
  "version": "1.0.0",
  "description": "Monitoring service for sparklock - sensor data collection and hazard detection",
  "license": "ISC",
  "author": "sparklock team",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@uploadthing/shared": "^7.1.10",
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "influx": "^5.12.0",
    "kafkajs": "^2.2.4",
    "mqtt": "^5.15.0",
    "pg": "^8.19.0",
    "socket.io": "^4.8.3",
    "uploadthing": "^7.7.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "fast-check": "^3.15.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/?(*.)+(spec|test).js"
    ]
  }
}
